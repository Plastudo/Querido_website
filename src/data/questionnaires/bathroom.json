{
  "workType": "bathroom",
  "questions": [
    {
      "id": "bathroom_area",
      "type": "number",
      "label": "Qual é a área total da sua casa de banho, em m²?",
      "hint": "Use comprimento × largura. Exemplo: 2,5 m × 2 m = 5 m²"
    },
    {
      "id": "bathroom_state",
      "type": "single_select",
      "label": "Qual é o estado atual da casa de banho?",
      "hint": "Escolha a opção que melhor descreve a situação. Pode sempre ajustar depois.",
      "options": [
        {
          "value": "full_demolition",
          "label": "Demolição completa",
          "description": "Retirar tudo: azulejos, pavimento, louças e canalizações existentes"
        },
        {
          "value": "partial_renovation",
          "label": "Renovação parcial",
          "description": "Retirar apenas alguns elementos e manter outros"
        },
        {
          "value": "just_finishing",
          "label": "Apenas acabamentos",
          "description": "Novos azulejos por cima dos existentes ou pintura, sem demolir nada"
        }
      ]
    },
    {
      "id": "demolition_area",
      "type": "number",
      "label": "Quantos m² precisam de demolição?",
      "hint": "Inclua azulejos, pavimento e outros elementos a retirar. Se não tem a certeza, use a área total da casa de banho.",
      "conditions": [
        { "questionId": "bathroom_state", "values": ["full_demolition", "partial_renovation"] }
      ],
      "generates": [
        { "budgetItemId": "lab_demolition", "mapping": "direct" }
      ]
    },
    {
      "id": "bathroom_floor",
      "type": "single_select",
      "label": "O que pretende fazer no pavimento?",
      "hint": "O pavimento cerâmico é o mais recomendado para casas de banho pela durabilidade.",
      "options": [
        {
          "value": "keep",
          "label": "Manter o pavimento atual",
          "description": "Sem obras no chão"
        },
        {
          "value": "new_ceramic",
          "label": "Novo pavimento cerâmico",
          "description": "Durável e resistente à humidade, ideal para casas de banho"
        }
      ]
    },
    {
      "id": "floor_ceramic_area",
      "type": "number",
      "label": "Quantos m² de pavimento cerâmico?",
      "hint": "Normalmente igual à área total da casa de banho. Adicione 10% para compensar o desperdício.",
      "conditions": [
        { "questionId": "bathroom_floor", "values": ["new_ceramic"] }
      ],
      "generates": [
        { "budgetItemId": "mat_floor_ceramic_tile",  "mapping": "direct" },
        { "budgetItemId": "mat_floor_tile_adhesive", "mapping": "direct" },
        { "budgetItemId": "mat_floor_tile_grout",    "mapping": "direct" },
        { "budgetItemId": "lab_floor_tiler",         "mapping": "direct" }
      ]
    },
    {
      "id": "bathroom_walls",
      "type": "single_select",
      "label": "O que pretende fazer nas paredes?",
      "hint": "A cobertura total oferece máxima proteção em zonas de duche e banheira.",
      "options": [
        {
          "value": "keep",
          "label": "Manter as paredes",
          "description": "Sem alterações nas paredes"
        },
        {
          "value": "full_tiles",
          "label": "Azulejos do chão ao teto",
          "description": "Cobertura total, máxima proteção contra humidade"
        },
        {
          "value": "partial_tiles_paint",
          "label": "Azulejos até meia parede + pintura",
          "description": "Solução intermédia e mais económica"
        }
      ]
    },
    {
      "id": "wall_full_tile_area",
      "type": "number",
      "label": "Quantos m² de azulejo para as paredes?",
      "hint": "Some: largura de cada parede × altura total (tipicamente 2,4 m). Adicione 10% para desperdício.",
      "conditions": [
        { "questionId": "bathroom_walls", "values": ["full_tiles"] }
      ],
      "generates": [
        { "budgetItemId": "mat_wall_tile",          "mapping": "direct" },
        { "budgetItemId": "mat_wall_tile_adhesive", "mapping": "direct" },
        { "budgetItemId": "mat_wall_tile_grout",    "mapping": "direct" },
        { "budgetItemId": "lab_wall_tiler",         "mapping": "direct" }
      ]
    },
    {
      "id": "wall_partial_tile_area",
      "type": "number",
      "label": "Quantos m² de azulejo (zona inferior)?",
      "hint": "Some: largura de cada parede × a altura até onde vai o azulejo (tipicamente 1,2 m). Adicione 10%.",
      "conditions": [
        { "questionId": "bathroom_walls", "values": ["partial_tiles_paint"] }
      ],
      "generates": [
        { "budgetItemId": "mat_wall_tile",          "mapping": "direct" },
        { "budgetItemId": "mat_wall_tile_adhesive", "mapping": "direct" },
        { "budgetItemId": "mat_wall_tile_grout",    "mapping": "direct" },
        { "budgetItemId": "lab_wall_tiler",         "mapping": "direct" }
      ]
    },
    {
      "id": "wall_partial_paint_area",
      "type": "number",
      "label": "Quantos m² de parede vai pintar (zona superior)?",
      "hint": "Some: largura de cada parede × altura da zona a pintar.",
      "conditions": [
        { "questionId": "bathroom_walls", "values": ["partial_tiles_paint"] }
      ],
      "generates": [
        { "budgetItemId": "mat_wall_primer_bath", "mapping": "direct" },
        { "budgetItemId": "mat_wall_paint_bath",  "mapping": "direct" },
        { "budgetItemId": "lab_wall_painter",     "mapping": "direct" }
      ]
    },
    {
      "id": "sanitary_scope",
      "type": "single_select",
      "label": "O que pretende fazer com as louças sanitárias?",
      "hint": "Inclui sanita, lavatório, duche e banheira.",
      "options": [
        {
          "value": "keep_all",
          "label": "Manter tudo",
          "description": "As louças atuais ficam no lugar"
        },
        {
          "value": "replace_all",
          "label": "Substituir tudo",
          "description": "Sanita, lavatório e duche/banheira novos"
        },
        {
          "value": "replace_partially",
          "label": "Substituir algumas peças",
          "description": "Escolho quais a substituir nas próximas perguntas"
        }
      ],
      "generates": [
        {
          "budgetItemId": "mat_toilet",
          "mapping": "lookup",
          "lookupTable": { "keep_all": 0, "replace_all": 1, "replace_partially": 0 }
        },
        {
          "budgetItemId": "lab_sanitary_install_toilet",
          "mapping": "lookup",
          "lookupTable": { "keep_all": 0, "replace_all": 1, "replace_partially": 0 }
        },
        {
          "budgetItemId": "mat_basin",
          "mapping": "lookup",
          "lookupTable": { "keep_all": 0, "replace_all": 1, "replace_partially": 0 }
        },
        {
          "budgetItemId": "lab_sanitary_install_basin",
          "mapping": "lookup",
          "lookupTable": { "keep_all": 0, "replace_all": 1, "replace_partially": 0 }
        }
      ]
    },
    {
      "id": "shower_bathtub_choice",
      "type": "single_select",
      "label": "Prefere duche ou banheira?",
      "hint": "Vai substituir toda a instalação de duche/banheira existente.",
      "conditions": [
        { "questionId": "sanitary_scope", "values": ["replace_all"] }
      ],
      "generates": [
        {
          "budgetItemId": "mat_shower_tray",
          "mapping": "lookup",
          "lookupTable": { "shower_tray": 1, "bathtub": 0 }
        },
        {
          "budgetItemId": "mat_bathtub",
          "mapping": "lookup",
          "lookupTable": { "shower_tray": 0, "bathtub": 1 }
        },
        {
          "budgetItemId": "lab_sanitary_install_shower_bath",
          "mapping": "lookup",
          "lookupTable": { "shower_tray": 1, "bathtub": 1 }
        }
      ],
      "options": [
        {
          "value": "shower_tray",
          "label": "Duche",
          "description": "Base de duche com estrutura e vidros, mais prático e acessível"
        },
        {
          "value": "bathtub",
          "label": "Banheira",
          "description": "Mais confortável, ideal para famílias com crianças"
        }
      ]
    },
    {
      "id": "replace_toilet",
      "type": "single_select",
      "label": "Pretende substituir a sanita?",
      "options": [
        { "value": "yes", "label": "Sim, substituir a sanita" },
        { "value": "no",  "label": "Não, manter a sanita atual" }
      ],
      "conditions": [
        { "questionId": "sanitary_scope", "values": ["replace_partially"] }
      ],
      "generates": [
        {
          "budgetItemId": "mat_toilet",
          "mapping": "lookup",
          "lookupTable": { "yes": 1, "no": 0 }
        },
        {
          "budgetItemId": "lab_sanitary_install_toilet",
          "mapping": "lookup",
          "lookupTable": { "yes": 1, "no": 0 }
        }
      ]
    },
    {
      "id": "replace_basin",
      "type": "single_select",
      "label": "Pretende substituir o lavatório?",
      "options": [
        { "value": "yes", "label": "Sim, substituir o lavatório" },
        { "value": "no",  "label": "Não, manter o lavatório atual" }
      ],
      "conditions": [
        { "questionId": "sanitary_scope", "values": ["replace_partially"] }
      ],
      "generates": [
        {
          "budgetItemId": "mat_basin",
          "mapping": "lookup",
          "lookupTable": { "yes": 1, "no": 0 }
        },
        {
          "budgetItemId": "lab_sanitary_install_basin",
          "mapping": "lookup",
          "lookupTable": { "yes": 1, "no": 0 }
        }
      ]
    },
    {
      "id": "replace_shower_or_bath",
      "type": "single_select",
      "label": "O que pretende fazer com o duche ou banheira?",
      "conditions": [
        { "questionId": "sanitary_scope", "values": ["replace_partially"] }
      ],
      "generates": [
        {
          "budgetItemId": "mat_shower_tray",
          "mapping": "lookup",
          "lookupTable": { "keep": 0, "shower_tray": 1, "bathtub": 0 }
        },
        {
          "budgetItemId": "mat_bathtub",
          "mapping": "lookup",
          "lookupTable": { "keep": 0, "shower_tray": 0, "bathtub": 1 }
        },
        {
          "budgetItemId": "lab_sanitary_install_shower_bath",
          "mapping": "lookup",
          "lookupTable": { "keep": 0, "shower_tray": 1, "bathtub": 1 }
        }
      ],
      "options": [
        {
          "value": "keep",
          "label": "Manter o duche / banheira",
          "description": "Sem alterações"
        },
        {
          "value": "shower_tray",
          "label": "Novo duche",
          "description": "Base de duche com estrutura e vidros"
        },
        {
          "value": "bathtub",
          "label": "Nova banheira",
          "description": "Mais confortável para toda a família"
        }
      ]
    },
    {
      "id": "bathroom_plumbing",
      "type": "single_select",
      "label": "O que vai ser feito na canalização de água?",
      "hint": "Mover louças de sítio implica obras de canalização adicionais.",
      "options": [
        {
          "value": "keep",
          "label": "Manter a canalização",
          "description": "Todas as louças ficam no mesmo sítio"
        },
        {
          "value": "move_points",
          "label": "Mudar alguns pontos de água",
          "description": "Deslocar uma ou mais louças de sítio"
        },
        {
          "value": "full_replumbing",
          "label": "Canalização nova de raiz",
          "description": "Tubagem de abastecimento e esgoto completamente nova"
        }
      ],
      "generates": [
        {
          "budgetItemId": "mat_pvc_pipe",
          "mapping": "lookup",
          "lookupTable": { "keep": 0, "move_points": 3, "full_replumbing": 8 }
        },
        {
          "budgetItemId": "mat_copper_pipe",
          "mapping": "lookup",
          "lookupTable": { "keep": 0, "move_points": 5, "full_replumbing": 12 }
        },
        {
          "budgetItemId": "lab_plumbing_hours",
          "mapping": "lookup",
          "lookupTable": { "keep": 0, "move_points": 8, "full_replumbing": 20 }
        }
      ]
    },
    {
      "id": "bathroom_electrical",
      "type": "single_select",
      "label": "O que vai ser feito na instalação elétrica?",
      "hint": "Em casas de banho, toda a instalação deve ser certificada IP44 ou superior.",
      "options": [
        {
          "value": "keep",
          "label": "Manter a instalação elétrica",
          "description": "Sem alterações nos circuitos existentes"
        },
        {
          "value": "add_towel_rail",
          "label": "Acrescentar toalheiro elétrico",
          "description": "Mantendo a instalação existente"
        },
        {
          "value": "full_rewiring",
          "label": "Instalação elétrica nova",
          "description": "Circuitos, caixas e pontos de luz todos novos"
        }
      ],
      "generates": [
        {
          "budgetItemId": "mat_electrical_cable",
          "mapping": "lookup",
          "lookupTable": { "keep": 0, "add_towel_rail": 5, "full_rewiring": 30 }
        },
        {
          "budgetItemId": "mat_electrical_box",
          "mapping": "lookup",
          "lookupTable": { "keep": 0, "add_towel_rail": 1, "full_rewiring": 5 }
        },
        {
          "budgetItemId": "mat_switch_socket",
          "mapping": "lookup",
          "lookupTable": { "keep": 0, "add_towel_rail": 0, "full_rewiring": 4 }
        },
        {
          "budgetItemId": "mat_towel_rail",
          "mapping": "lookup",
          "lookupTable": { "keep": 0, "add_towel_rail": 1, "full_rewiring": 0 }
        },
        {
          "budgetItemId": "lab_electrical_hours",
          "mapping": "lookup",
          "lookupTable": { "keep": 0, "add_towel_rail": 3, "full_rewiring": 16 }
        }
      ]
    },
    {
      "id": "bathroom_ventilation",
      "type": "single_select",
      "label": "Como está a ventilação da casa de banho?",
      "hint": "A ventilação adequada é essencial para evitar humidade e bolor.",
      "options": [
        {
          "value": "existing",
          "label": "Já tem ventilação suficiente",
          "description": "Janela ou extrator existente em bom estado"
        },
        {
          "value": "add_extractor",
          "label": "Instalar extrator de ar novo",
          "description": "Essencial para evitar humidade e bolor sem janela"
        }
      ],
      "generates": [
        {
          "budgetItemId": "mat_extractor_fan",
          "mapping": "lookup",
          "lookupTable": { "existing": 0, "add_extractor": 1 }
        },
        {
          "budgetItemId": "lab_electrical_hours",
          "mapping": "lookup",
          "lookupTable": { "existing": 0, "add_extractor": 2 }
        }
      ]
    }
  ],

